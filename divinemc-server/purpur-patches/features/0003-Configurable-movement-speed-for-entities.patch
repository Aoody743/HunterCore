Subject: [PATCH] Configurable movement speed for entities


diff --git a/src/main/java/org/purpurmc/purpur/PurpurWorldConfig.java b/src/main/java/org/purpurmc/purpur/PurpurWorldConfig.java
index 1322b750b834e5a1ee337d79766b2da6fc578716..5666c0ff15edf2992d97e92294ae96ca21935fdd 100644
--- a/src/main/java/org/purpurmc/purpur/PurpurWorldConfig.java
+++ b/src/main/java/org/purpurmc/purpur/PurpurWorldConfig.java
@@ -1805,6 +1805,7 @@ public class PurpurWorldConfig {
     public boolean drownedBreakDoors = false;
     public boolean drownedAlwaysDropExp = false;
     public Boolean drownedCanPickUpLoot = null;
+    public double drownedMovementSpeed = 0.23F; // DivineMC - Configurable movement speed for entities
     private void drownedSettings() {
         drownedRidable = getBoolean("mobs.drowned.ridable", drownedRidable);
         drownedRidableInWater = getBoolean("mobs.drowned.ridable-in-water", drownedRidableInWater);
@@ -1824,6 +1825,7 @@ public class PurpurWorldConfig {
         drownedBreakDoors = getBoolean("mobs.drowned.can-break-doors", drownedBreakDoors);
         drownedAlwaysDropExp = getBoolean("mobs.drowned.always-drop-exp", drownedAlwaysDropExp);
         drownedCanPickUpLoot = getBooleanOrDefault("mobs.drowned.can-pick-up-loot", drownedCanPickUpLoot);
+        drownedMovementSpeed = getDouble("mobs.drowned.movement-speed", drownedMovementSpeed); // DivineMC - Configurable movement speed for entities
     }
 
     public boolean elderGuardianRidable = false;
