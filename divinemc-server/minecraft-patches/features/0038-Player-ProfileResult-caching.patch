@@ -71,6 +71,11 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
     private int velocityLoginMessageId = -1; // Paper - Add Velocity IP Forwarding Support
     public java.util.@Nullable UUID requestedUuid; // Paper
     private final io.papermc.paper.connection.PaperPlayerLoginConnection paperLoginConnection; // Paper - Config API
+    // DivineMC start - Player ProfileResult caching
+    private static final com.google.common.cache.Cache<String, ProfileResult> playerProfileResultCache = com.google.common.cache.CacheBuilder.newBuilder()
+        .expireAfterWrite(org.bxteam.divinemc.config.DivineConfig.NetworkCategory.playerProfileResultCachingTimeout, java.util.concurrent.TimeUnit.MINUTES)
+        .build();
+    // DivineMC end - Player ProfileResult caching
 
     public ServerLoginPacketListenerImpl(final MinecraftServer minecraftserver, final Connection connection, final boolean transferred) {
         this.server = minecraftserver;
@@ -265,10 +270,25 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
                 String name = Objects.requireNonNull(ServerLoginPacketListenerImpl.this.requestedUsername, "Player name not initialized");
 
                 try {
-                    ProfileResult result = ServerLoginPacketListenerImpl.this.server
-                        .services()
-                        .sessionService()
-                        .hasJoinedServer(name, digest, this.getAddress());
+                    // DivineMC start - Player ProfileResult caching
+                    ProfileResult result;
+                    if (org.bxteam.divinemc.config.DivineConfig.NetworkCategory.playerProfileResultCachingEnabled) {
+                        result = playerProfileResultCache.getIfPresent(name);
+
+                        if (result == null) {
+                            result = ServerLoginPacketListenerImpl.this.server
+                                .services()
+                                .sessionService()
+                                .hasJoinedServer(name, digest, this.getAddress());
+                            playerProfileResultCache.put(name, result);
+                        }
+                    } else {
+                        result = ServerLoginPacketListenerImpl.this.server
+                            .services()
+                            .sessionService()
+                            .hasJoinedServer(name, digest, this.getAddress());
+                    }
+                    // DivineMC end - Player ProfileResult caching
                     if (result != null) {
                         GameProfile profile = result.profile();
                         // CraftBukkit start - fire PlayerPreLoginEvent
