         );
         ItemStack itemStack = player.getItemInHand(hand);
         if (!clouds.isEmpty()) {
+            // DivineMC start - Paper PR: Add FillBottleEvents for player and dispenser
+            final io.papermc.paper.event.player.PlayerFillBottleEvent event = org.bukkit.craftbukkit.event.CraftEventFactory.callPlayerFillBottleEvent(player, hand, itemStack, new ItemStack(Items.DRAGON_BREATH));
+            //noinspection DuplicatedCode
+            if (event.isCancelled()) {
+                player.containerMenu.sendAllDataToRemote();
+                return InteractionResult.PASS;
+            }
+            final ItemStack resultItem = org.bukkit.craftbukkit.inventory.CraftItemStack.asNMSCopy(event.getResultItem());
+            if (resultItem.is(itemStack.getItem())) {
+                player.containerMenu.sendAllDataToRemote();
+            }
