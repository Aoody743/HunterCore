+            BlockState aquiferState = closestStatus1.at(posY);
+            if (similarityFirstSecond <= 0.0) {
+                this.shouldScheduleFluidUpdate = similarityFirstSecond >= FLOWING_UPDATE_SIMULARITY;
+                return aquiferState;
+            } else if (aquiferState.is(Blocks.WATER) && this.globalFluidPicker.computeFluid(posX, posY - 1, posZ).at(posY - 1).is(Blocks.LAVA)) {
+                this.shouldScheduleFluidUpdate = true;
