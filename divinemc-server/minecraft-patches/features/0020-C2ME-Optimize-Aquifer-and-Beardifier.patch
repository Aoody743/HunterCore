+        private void aquiferExtracted$refreshDistPosIdx(final int blockX, final int blockY, final int blockZ) {
+            int gridX = (blockX - 5) >> 4;
+            int gridY = Math.floorDiv(blockY + 1, 12);
+            int gridZ = (blockZ - 5) >> 4;
+            int closest1 = Integer.MAX_VALUE;
+            int closest2 = Integer.MAX_VALUE;
+            int closest3 = Integer.MAX_VALUE;
+
+            int sampleIndex = 12; // 12 max
+            for (int offY = -1; offY <= 1; ++offY) {
+                int gridYBlockBase = (gridY + offY) * 12;
+                for (int offZ = 0; offZ <= 1; ++offZ) {
+                    int gridZBlockBase = (gridZ + offZ) << 4;
+
+                    int leftSampleIndex = sampleIndex - 1;
+                    int leftPosIdx = this.getIndex(gridX, gridY + offY, gridZ + offZ);
+                    int leftPacked = this.c2me$packedBlockPositions[leftPosIdx];
+                    int leftDx = (gridX << 4) + c2me$unpackPackedX(leftPacked) - blockX;
+                    int leftDy = gridYBlockBase + c2me$unpackPackedY(leftPacked) - blockY;
+                    int leftDz = gridZBlockBase + c2me$unpackPackedZ(leftPacked) - blockZ;
+                    int leftDistSqr = leftDx * leftDx + leftDy * leftDy + leftDz * leftDz;
+
+                    int rightSampleIndex = sampleIndex - 2;
+                    int rightPosIdx = leftPosIdx + 1;
+                    int rightPacked = this.c2me$packedBlockPositions[rightPosIdx];
+                    int rightDx = ((gridX + 1) << 4) + c2me$unpackPackedX(rightPacked) - blockX;
+                    int rightDy = gridYBlockBase + c2me$unpackPackedY(rightPacked) - blockY;
+                    int rightDz = gridZBlockBase + c2me$unpackPackedZ(rightPacked) - blockZ;
+                    int rightDistSqr = rightDx * rightDx + rightDy * rightDy + rightDz * rightDz;
+
+                    int leftPackedKey = (leftDistSqr << 20) | (leftSampleIndex << 16) | leftPosIdx;
+                    if (leftPackedKey <= closest3) {
+                        int swapLeft1 = Math.max(closest1, leftPackedKey);
+                        closest1 = Math.min(closest1, leftPackedKey);
+
+                        int swapLeft2 = Math.max(closest2, swapLeft1);
+                        closest2 = Math.min(closest2, swapLeft1);
+
+                        closest3 = Math.min(closest3, swapLeft2);
+                    }
+
+                    int rightPackedKey = (rightDistSqr << 20) | (rightSampleIndex << 16) | rightPosIdx;
+                    if (rightPackedKey <= closest3) {
+                        int swapRight1 = Math.max(closest1, rightPackedKey);
+                        closest1 = Math.min(closest1, rightPackedKey);
+
+                        int swapRight2 = Math.max(closest2, swapRight1);
+                        closest2 = Math.min(closest2, swapRight1);
