+        private static double aquiferExtracted$getQ(final double posY, final double averageFluidY, final double fluidYDiff) {
+            double yDistFromAvg = posY + 0.5 - averageFluidY;
+            double halfRange = fluidYDiff / 2.0;
+            double rangeMinusDist = halfRange - Math.abs(yDistFromAvg);
+            double pressure;
+            if (yDistFromAvg > 0.0) {
+                if (rangeMinusDist > 0.0) {
+                    pressure = rangeMinusDist / 1.5;
+                } else {
+                    pressure = rangeMinusDist / 2.5;
+                }
+            } else {
+                double shifted = 3.0 + rangeMinusDist;
+                if (shifted > 0.0) {
+                    pressure = shifted / 3.0;
+                } else {
