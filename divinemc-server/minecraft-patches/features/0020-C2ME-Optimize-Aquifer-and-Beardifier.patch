+            double similarityFirstThird = similarity(c2me$unpackPackedDist(this.c2me$packed1), dist3);
+            if (aquiferExtracted$extractedCheckFG(context, density, similarityFirstSecond, closestStatus1, similarityFirstThird, closestStatus3)) return null;
+
+            double similaritySecondThird = similarity(c2me$unpackPackedDist(this.c2me$packed2), dist3);
