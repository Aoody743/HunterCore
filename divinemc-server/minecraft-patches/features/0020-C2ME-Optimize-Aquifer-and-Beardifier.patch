+        private boolean aquiferExtracted$extractedCheckFG(final DensityFunction.FunctionContext context, final double density, final double primarySimilarity, final Aquifer.FluidStatus statusA, final double secondarySimilarity, final Aquifer.FluidStatus statusB) {
+            if (secondarySimilarity > 0.0) {
